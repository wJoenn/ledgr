{
  "$schema": "./node_modules/turbo/schema.json",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "generate": {
      "outputs": [
        ".nuxt/**",
        ".output/**",
        "dist/**"
      ]
    },
    "lint": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "!.nuxt/**",
        "!.output/**",
      ]
    },
    "test": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "!.nuxt/**",
        "!.output/**",
      ]
    },
    "typecheck": {
      "inputs": [
        "$TURBO_DEFAULT$",
        "!.nuxt/**",
        "!.output/**",
      ]
    }
  },
  "ui": "tui"
}
